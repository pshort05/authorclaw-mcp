{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "authorclaw",
  "description": "AuthorClaw writing agent — chat, projects, files, research",
  "status": "active",
  "repository": {
    "url": "https://github.com/pshort05/authorclaw-mcp",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "authorclaw-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "AUTHORCLAW_URL",
          "description": "URL of your AuthorClaw gateway",
          "default": "http://127.0.0.1:18789",
          "isRequired": true
        },
        {
          "name": "AUTHORCLAW_API_TOKEN",
          "description": "Bearer token for AuthorClaw gateway authentication",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "AUTHORCLAW_MODEL",
          "description": "Model name for chat completions (e.g. 'authorclaw' or 'authorclaw/<agentId>')",
          "default": "authorclaw",
          "isRequired": false
        },
        {
          "name": "AUTHORCLAW_TIMEOUT_MS",
          "description": "Request timeout in milliseconds",
          "default": "120000",
          "isRequired": false
        }
      ]
    },
    {
      "registryType": "oci",
      "identifier": "ghcr.io/pshort05/authorclaw-mcp",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "AUTHORCLAW_URL",
          "description": "URL of your AuthorClaw gateway",
          "default": "http://127.0.0.1:18789",
          "isRequired": true
        },
        {
          "name": "AUTHORCLAW_API_TOKEN",
          "description": "Bearer token for AuthorClaw gateway authentication",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "AUTHORCLAW_MODEL",
          "description": "Model name for chat completions",
          "default": "authorclaw",
          "isRequired": false
        }
      ]
    }
  ]
}
